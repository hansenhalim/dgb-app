# Selects which data adapters back the app.
#   mock → in-memory fakes (seeded dashboard, 120ms latency) — default for dev
#   real → hits EXPO_PUBLIC_API_BASE_URL
EXPO_PUBLIC_API_MODE=mock

# Selects which RFID reader implementation to use.
#   mock   → MockRfidReader (simulated scans, useful in simulator)
#   ble    → BleRfidReader (stub — wire up when BLE hardware is chosen)
#   serial → SerialRfidReader (stub — wire up when serial/USB hardware is chosen)
EXPO_PUBLIC_RFID_TRANSPORT=mock

# Base URL used by the real API adapters. Ignored when EXPO_PUBLIC_API_MODE=mock.
EXPO_PUBLIC_API_BASE_URL=
