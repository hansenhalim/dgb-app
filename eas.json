{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "staging": {
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "staging"
      }
    },
    "production": {
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
